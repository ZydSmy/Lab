<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Blood Lab - Results</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { display: flex; background: #f4f7f6; min-height: 100vh; font-family: 'Segoe UI', sans-serif; }
        .sidebar { width: 260px; background: #2c3e50; color: white; position: fixed; height: 100%; transition: 0.3s; }
        .sidebar a { color: #adb5bd; padding: 15px 25px; display: block; text-decoration: none; border-left: 4px solid transparent; }
        .sidebar a:hover, .sidebar a.active { background: #34495e; color: white; border-left: 4px solid #3498db; }
        .main-content { margin-left: 260px; width: 100%; padding: 40px; }
        .card { border: none; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
        .status-badge { padding: 6px 12px; border-radius: 20px; font-weight: 600; font-size: 0.8rem; }
    </style>
</head>
<body>

<!-- Sidebar -->
<div class="sidebar">
    <div class="text-center py-5">
        <h4 class="text-white fw-bold"><i class="fas fa-droplet text-danger me-2"></i>LAB SYS</h4>
    </div>
    <a href="/results" class="active"><i class="fas fa-file-medical me-2"></i> Lab Results</a>
    <a href="/patients"><i class="fas fa-users me-2"></i> Patients</a>
    <a href="/doctors"><i class="fas fa-user-md me-2"></i> Doctors List</a>
    <a href="/test-types"><i class="fas fa-microscope me-2"></i> Test Types</a>
</div>

<!-- Main Content -->
<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Blood Analysis Records</h2>
        <button class="btn btn-primary btn-lg rounded-pill" data-bs-toggle="modal" data-bs-target="#addResultModal">
            <i class="fas fa-plus me-2"></i>New Analysis
        </button>
    </div>

    <!-- Search Section -->
    <div class="card p-3 mb-4">
        <form action="/results" method="GET" class="d-flex">
            <input type="text" name="search" class="form-control border-0 bg-light me-2" placeholder="Search by patient name..." value="<%= searchTerm %>">
            <button class="btn btn-dark px-4 rounded-pill">Search</button>
        </form>
    </div>

    <!-- Table Section -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Patient Name</th>
                        <th>Test Type</th>
                        <th>Measured Value</th>
                        <th>Result Status</th>
                        <th>Doctor</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    <% history.forEach(r => { %>
                    <tr class="align-middle">
                        <td class="ps-4"><strong><%= r.patientId ? r.patientId.name : 'Deleted' %></strong></td>
                        <td><span class="text-primary fw-bold"><%= r.testTypeId ? r.testTypeId.testName : 'N/A' %></span></td>
                        <td><%= r.value %> <small class="text-muted"><%= r.testTypeId?.unit %></small></td>
                        <td>
                            <span class="status-badge <%= r.status === 'Natural' ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' %>">
                                <i class="fas <%= r.status === 'Natural' ? 'fa-check-circle' : 'fa-exclamation-circle' %> me-1"></i>
                                <%= r.status %>
                            </span>
                        </td>
                        <td><%= r.doctorId ? r.doctorId.name : 'General' %></td>
                        <td class="text-muted small"><%= r.createdAt.toLocaleDateString() %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Result Modal -->
<div class="modal fade" id="addResultModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <form action="/results/add" method="POST" class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title">Record New Analysis</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">Select Patient</label>
                    <select name="patientId" class="form-select" required>
                        <% patients.forEach(p => { %> <option value="<%= p._id %>"><%= p.name %></option> <% }) %>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Test Type</label>
                    <select name="testTypeId" class="form-select" required>
                        <% tests.forEach(t => { %> <option value="<%= t._id %>"><%= t.testName %></option> <% }) %>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Value</label>
                    <input type="number" step="0.1" name="value" class="form-control" placeholder="Enter measurement" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Assigned Doctor</label>
                    <select name="doctorId" class="form-select">
                        <% doctors.forEach(d => { %> <option value="<%= d._id %>"><%= d.name %></option> <% }) %>
                    </select>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Process & Save</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>