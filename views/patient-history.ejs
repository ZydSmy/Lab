<<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Patient History - <%= patient.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { display: flex; background: #f4f7f6; min-height: 100vh; font-family: 'Segoe UI', sans-serif; }
        .sidebar { width: 260px; background: #2c3e50; color: white; position: fixed; height: 100%; }
        .sidebar a { color: #adb5bd; padding: 15px 25px; display: block; text-decoration: none; }
        .main-content { margin-left: 260px; width: 100%; padding: 40px; }
        .patient-card { background: white; border-radius: 15px; padding: 25px; margin-bottom: 30px; border-left: 5px solid #3498db; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="text-center py-5"><h4 class="text-white fw-bold">LAB SYS</h4></div>
    <a href="/results"><i class="fas fa-arrow-left me-2"></i> Back to All Results</a>
    <a href="/patients"><i class="fas fa-users me-2"></i> Back to Patients</a>
</div>

<div class="main-content">
    <!-- Patient Info Header -->
    <div class="patient-card shadow-sm">
        <div class="row align-items-center">
            <div class="col-md-1 text-center">
                <i class="fas fa-user-circle fa-4x text-secondary"></i>
            </div>
            <div class="col-md-11">
                <h2 class="fw-bold mb-1"><%= patient.name %></h2>
                <p class="text-muted mb-0">
                    <span class="me-3"><strong>Age:</strong> <%= patient.age %></span>
                    <span class="me-3"><strong>Gender:</strong> <%= patient.gender %></span>
                    <span><strong>Phone:</strong> <%= patient.phone %></span>
                </p>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3">All Test Records</h4>
    <div class="card border-0 shadow-sm overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Date</th>
                    <th>Test Type</th>
                    <th>Measured Value</th>
                    <th>Result Status</th>
                    <th>Doctor</th>
                </tr>
            </thead>
            <tbody>
                <% if(results.length > 0) { %>
                    <% results.forEach(r => { %>
                    <tr class="align-middle">
                        <td class="ps-4 text-muted"><%= r.createdAt.toLocaleDateString() %></td>
                        <td><span class="fw-bold text-primary"><%= r.testTypeId ? r.testTypeId.testName : 'N/A' %></span></td>
                        <td><%= r.value %> <small><%= r.testTypeId?.unit %></small></td>
                        <td>
                            <span class="badge rounded-pill <%= r.status === 'Natural' ? 'bg-success' : 'bg-danger' %>">
                                <%= r.status %>
                            </span>
                        </td>
                        <td><%= r.doctorId ? r.doctorId.name : 'N/A' %></td>
                    </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No test records found for this patient.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

</body>
</html>